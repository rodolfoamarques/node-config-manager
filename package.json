{
  "author": "Rodolfo Marques",
  "bugs": {
    "url": "https://github.com/rodolfoamarques/node-config-manager/issues"
  },
  "dependencies": {
    "deepmerge-ts": "7.1.5",
    "joi": "18.2.3",
    "js-yaml": "5.0.0"
  },
  "description": "Config Management library for NodeJS applications",
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/js-yaml": "4.0.9",
    "@types/mocha": "10.0.10",
    "@types/node": "26.0.0",
    "@types/sinon": "21.0.1",
    "c8": "11.0.0",
    "chai": "6.2.2",
    "esmock": "2.7.6",
    "mocha": "11.7.6",
    "rimraf": "6.1.3",
    "sinon": "22.0.0",
    "typescript": "6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "homepage": "https://github.com/rodolfoamarques/node-config-manager#readme",
  "keywords": [
    "Configuration",
    "Library",
    "NodeJS"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "mocha": {
    "check-leaks": true,
    "color": true,
    "diff": true,
    "exit": true,
    "extension": [
      "ts",
      "cjs",
      "mjs",
      "cts",
      "mts"
    ],
    "inspect": 9231,
    "parallel": false,
    "recursive": true,
    "reporter": "spec",
    "reporter-option": [
      "maxDiffSize=0"
    ],
    "slow": 1000,
    "spec": [
      "__tests__/**/*.spec.ts"
    ],
    "timeout": 5000,
    "ui": "bdd"
  },
  "module": "./dist/index.js",
  "name": "node-config-manager",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodolfoamarques/node-config-manager.git"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "clean": "yarn clean:build && yarn clean:test",
    "clean:build": "tsc --build --clean && rimraf build dist",
    "clean:test": "rimraf coverage",
    "reset": "yarn clean && rimraf node_modules && rm yarn.lock",
    "test": "yarn clean:test && c8 -c .c8rc.json mocha"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "1.0.0"
}
